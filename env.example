# NATS (overridden by docker-compose)
NATS_URL=nats://localhost:4222

# RAG service (overridden by docker-compose)
RAG_SERVICE_URL=http://localhost:8001
RAG_TIMEOUT_SECONDS=10

# Meilisearch (overridden by docker-compose)
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=openclaw-dev-key

# Speaches — TTS/STT disabled for now
SPEACHES_URL=http://localhost:8014
SPEACHES_MODEL=Systran/faster-whisper-large-v3
SPEACHES_TIMEOUT_SECONDS=300

# Shell proxy (OpenAI compat endpoint)
OPENAI_GATEWAY_URL=http://localhost:8080

# Frontend
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=INFO

# Conversation RAG indexing threshold
RAG_INDEX_THRESHOLD=20

# MCP service shared secret (must match MCP_SERVICE_API_KEY in goclaw/.env)
MCP_SERVICE_KEY=a52d7c4423e730231c8f2e510bc43d1f2d0ea18a5fdc88b6fe10bf9e35e54ee4
MCP_SERVICE_API_KEY=a52d7c4423e730231c8f2e510bc43d1f2d0ea18a5fdc88b6fe10bf9e35e54ee4

# Parser S3 credentials (reuse Garage keys)
PARSER_S3_ACCESS_KEY=GK69c1e0b81fc3aa9cea6a491f
PARSER_S3_SECRET_KEY=35ef7aee237df2525623a7f038911a75e22e5e4c39d063afd2748baf7016304b

# Embeddings — Qwen3-Embedding-0.6B via LiteLLM → Ollama (dense, 1024-dim)
RAG_EMBEDDING_URL=http://host.docker.internal:4000/v1
RAG_EMBEDDING_MODEL=text-embedding-qwen3
RAG_EMBEDDING_API_KEY=sk-local-dev
PARSER_EMBEDDING_URL=http://host.docker.internal:4000/v1
PARSER_EMBEDDING_MODEL=text-embedding-qwen3
PARSER_EMBEDDING_API_KEY=sk-local-dev

# docling-serve — stable v1 API (ghcr.io/docling-project/docling-serve-cu130:main)
PARSER_DOCLING_URL=http://host.docker.internal:5001

# ─── GoClaw ──────────────────────────────────────────────────────────────────
# URL from REST API container perspective (host.docker.internal = host machine)
GOCLAW_GATEWAY_URL=http://host.docker.internal:18790
GOCLAW_GATEWAY_TOKEN=dbf889b91fc805a5d23065b70705fdd94747e5b1e8470167cdf875cfeff6bf29
GOCLAW_DEFAULT_MODEL=qwen3.5:9b
# LiteLLM proxy URL as seen by GoClaw (host.docker.internal:4000 from goclaw container)
# Used here by REST API to register the provider; GoClaw calls it from its own network
GOCLAW_LITELLM_URL=http://host.docker.internal:4000/v1
GOCLAW_LITELLM_API_KEY=sk-local-dev
# MCP server URL as seen FROM GoClaw container (same Docker network = service name)
GOCLAW_MCP_URL=http://mcp:8002
GOCLAW_MCP_TOOL_PREFIX=ws
# Embedding model (must match a model in LiteLLM config)
GOCLAW_EMBEDDING_MODEL=text-embedding-qwen3
# TTS disabled until Speaches is running
GOCLAW_TTS_PROVIDER=off
GOCLAW_TTS_AUTO=inbound
GOCLAW_TTS_VOICE=af_heart
GOCLAW_TTS_EDGE_VOICE=en-US-JennyNeural
# Skills
GOCLAW_DEFAULT_SKILLS=workspace-assistant
GOCLAW_SKILLS_DIR=/skills
GOCLAW_AGENT_TYPE=open
GOCLAW_AGENT_DESCRIPTION=
