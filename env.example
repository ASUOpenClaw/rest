# openclaw REST — environment variable schema.
# All values live in Infisical. This file documents keys only.
#
# Local dev without Infisical:
#   cp env.example .env && fill in values
#
# Production:
#   infisical run --env=prod -- docker-compose up -d

# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg DSN; docker-compose overrides to postgres container
DATABASE_URL=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# Generate: openssl genrsa -out jwt_private.pem 2048
#           openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# Store PEM as single-line \n-escaped string
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=525600

# ── OAuth — Yandex (optional) ─────────────────────────────────────────────────
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=

# ── OAuth — GitHub (optional) ─────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=

# ── S3 / Garage ───────────────────────────────────────────────────────────────
# docker-compose overrides S3_ENDPOINT_URL to the garage container
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=openclaw
S3_REGION=us-east-1

# ── NATS ─────────────────────────────────────────────────────────────────────
NATS_URL=

# ── RAG service ───────────────────────────────────────────────────────────────
RAG_SERVICE_URL=
RAG_TIMEOUT_SECONDS=10

# ── Meilisearch ───────────────────────────────────────────────────────────────
MEILISEARCH_URL=
MEILISEARCH_API_KEY=

# ── Speaches (STT/TTS) ────────────────────────────────────────────────────────
SPEACHES_URL=
SPEACHES_MODEL=Systran/faster-whisper-large-v3
SPEACHES_TIMEOUT_SECONDS=300

# ── LiteLLM proxy ────────────────────────────────────────────────────────────
LITELLM_URL=
LITELLM_BASE_URL=
LITELLM_MASTER_KEY=

# ── RAG / Parser embedding ────────────────────────────────────────────────────
RAG_EMBEDDING_MODEL=text-embedding-qwen3
RAG_EMBEDDING_API_KEY=
PARSER_EMBEDDING_MODEL=text-embedding-qwen3
PARSER_EMBEDDING_API_KEY=

# ── Docling (document parsing) ────────────────────────────────────────────────
PARSER_DOCLING_URL=
PARSER_DOCLING_API_KEY=

# ── GoClaw AI agent gateway ───────────────────────────────────────────────────
# docker-compose overrides GOCLAW_GATEWAY_URL to goclaw container
GOCLAW_GATEWAY_URL=
# Bearer token for GoClaw admin API
GOCLAW_GATEWAY_TOKEN=
# Shared secret for turn-event / file-created webhooks (must match goclaw config)
GOCLAW_WEBHOOK_SECRET=
# Default LLM model (must match a model_name in litellm config)
GOCLAW_DEFAULT_MODEL=qwen3
# Internal URL GoClaw uses to reach LiteLLM (docker-compose overrides)
GOCLAW_LITELLM_URL=
# Public URL registered as provider api_base in GoClaw
GOCLAW_LITELLM_API_BASE=
GOCLAW_LITELLM_API_KEY=
# Embedding model for GoClaw vector memory (must match litellm config)
GOCLAW_EMBEDDING_MODEL=text-embedding-qwen3
# TTS: openai | edge | off
GOCLAW_TTS_PROVIDER=openai
GOCLAW_TTS_AUTO=inbound
GOCLAW_TTS_VOICE=af_heart
GOCLAW_TTS_EDGE_VOICE=en-US-JennyNeural
# Skill catalog names granted to every new workspace agent (comma-separated)
GOCLAW_DEFAULT_SKILLS=workspace-assistant
GOCLAW_SKILLS_DIR=/skills
GOCLAW_AGENT_TYPE=open
GOCLAW_AGENT_DESCRIPTION=

# ── Tools service ─────────────────────────────────────────────────────────────
TOOLS_SERVICE_URL=
TOOLS_SERVICE_KEY=

# ── Background sync ───────────────────────────────────────────────────────────
GOCLAW_SYNC_INTERVAL_SECONDS=300

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=
FRONTEND_URL=
