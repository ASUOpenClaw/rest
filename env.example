# Database
DATABASE_URL=postgresql+asyncpg://openclaw:openclaw@localhost:5432/openclaw

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# OAuth — Yandex
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://localhost:8000/v1/auth/yandex/callback

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/v1/auth/github/callback

# S3 / Garage
S3_ENDPOINT_URL=http://localhost:3900
S3_ACCESS_KEY_ID=GK69c1e0b81fc3aa9cea6a491f
S3_SECRET_ACCESS_KEY=35ef7aee237df2525623a7f038911a75e22e5e4c39d063afd2748baf7016304b
S3_BUCKET=openclaw
S3_REGION=us-east-1

# NATS
NATS_URL=nats://localhost:4222

# RAG service
RAG_SERVICE_URL=http://localhost:8001
RAG_TIMEOUT_SECONDS=10

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=openclaw-dev-key

# Speaches (Whisper HTTP server, OpenAI-compatible)
SPEACHES_URL=http://localhost:8080
SPEACHES_MODEL=Systran/faster-whisper-large-v3
SPEACHES_TIMEOUT_SECONDS=300

# OpenClaw gateway (OpenAI-compatible proxy)
OPENAI_GATEWAY_URL=http://localhost:8080

# Frontend
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=INFO

# Conversation RAG indexing threshold
RAG_INDEX_THRESHOLD=20

# MCP service shared secret (must match between REST API and MCP service)
MCP_SERVICE_KEY=change-me-mcp-secret
MCP_SERVICE_API_KEY=change-me-mcp-secret

# Parser S3 credentials (reuse Garage keys from above)
PARSER_S3_ACCESS_KEY=GK69c1e0b81fc3aa9cea6a491f
PARSER_S3_SECRET_KEY=35ef7aee237df2525623a7f038911a75e22e5e4c39d063afd2748baf7016304b

# GPU server services (TEI embeddings + docling-serve parsing)
# Replace <gpu-server-ip> with the actual IP or hostname of your GPU machine
RAG_TEI_URL=http://<gpu-server-ip>:8080
PARSER_TEI_URL=http://<gpu-server-ip>:8080
PARSER_DOCLING_URL=http://<gpu-server-ip>:5001
