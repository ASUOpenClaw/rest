# ── Database ──────────────────────────────────────────────────────────────────
# AsyncPG DSN for the main database.
# docker-compose overrides this to the postgres container for the api service;
# this value is used when running the API locally without compose.
DATABASE_URL=postgresql+asyncpg://openclaw:openclaw@localhost:5432/openclaw

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used for session caching and rate limiting.
# docker-compose overrides to the redis container.
REDIS_URL=redis://localhost:6379/0

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# Generate a key pair:
#   openssl genrsa -out jwt_private.pem 2048
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# Paste the PEM contents as a single \n-escaped line (python-dotenv decodes \n).
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
# Access token lifetime in minutes (default: 525600 = 1 year)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── OAuth — Yandex (optional) ─────────────────────────────────────────────────
# Leave empty to disable Yandex login.
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=http://localhost:8000/auth/yandex/callback

# ── OAuth — GitHub (optional) ─────────────────────────────────────────────────
# Leave empty to disable GitHub login.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# ── S3 / Garage ───────────────────────────────────────────────────────────────
# Shared by the API, RAG, and Parser services — one set of credentials for all.
# docker-compose overrides S3_ENDPOINT_URL per-container with the garage service name;
# this value is used for local runs outside compose.
S3_ENDPOINT_URL=http://localhost:3900
# Garage access key (generate with: garage key create)
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=openclaw
S3_REGION=us-east-1

# ── NATS ──────────────────────────────────────────────────────────────────────
# JetStream broker for async job queues (indexing, transcription).
# docker-compose overrides to the nats container.
NATS_URL=nats://localhost:4222

# ── RAG service ───────────────────────────────────────────────────────────────
# Internal RAG microservice URL (Qdrant + embeddings).
# docker-compose overrides to the rag container.
RAG_SERVICE_URL=http://localhost:8001
# Timeout (seconds) for RAG search requests
RAG_TIMEOUT_SECONDS=10
# Number of conversation messages that trigger auto-indexing into RAG
RAG_INDEX_THRESHOLD=20

# ── Meilisearch ───────────────────────────────────────────────────────────────
# Full-text search engine for workspaces and files.
# docker-compose overrides URL to the meilisearch container.
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=openclaw-dev-key

# ── Embeddings ────────────────────────────────────────────────────────────────
# Model and API key used by the RAG and Parser services when calling the
# embeddings endpoint (LiteLLM proxy).
# Both variables must point to the externally-reachable LiteLLM on the GPU server when
# RAG/Parser run on a different host than LiteLLM.
# LITELLM_URL      — used as RAG_EMBEDDING_URL and PARSER_EMBEDDING_URL (includes /v1)
# LITELLM_BASE_URL — used as PARSER_SPEACHES_URL for Whisper transcriptions (no /v1)
LITELLM_URL=http://<gpu-server-ip>:4000/v1
LITELLM_BASE_URL=http://<gpu-server-ip>:4000
LITELLM_API_KEY=sk-local-dev
# Model must match a model_name in the active litellm config (llms/litellm_config.*.yaml).
RAG_EMBEDDING_MODEL=text-embedding-qwen3
RAG_EMBEDDING_API_KEY=sk-local-dev
PARSER_EMBEDDING_MODEL=text-embedding-qwen3
PARSER_EMBEDDING_API_KEY=sk-local-dev

# ── Docling ───────────────────────────────────────────────────────────────────
# Document parsing service (PDF layout + OCR, DOCX, images → markdown).
# URL of the docling-serve container (may be on a separate GPU machine).
PARSER_DOCLING_URL=http://130.193.36.58:5001
# API key for docling-serve (leave empty if auth is disabled).
PARSER_DOCLING_API_KEY=

# ── Speaches — STT / TTS ─────────────────────────────────────────────────────
# Whisper (STT) and Kokoro (TTS) via the Speaches server.
# The Parser service routes transcriptions through LiteLLM (LITELLM_BASE_URL above).
# SPEACHES_URL is only used by the REST API for direct health-checking.
SPEACHES_URL=http://<gpu-server-ip>:8014
# Whisper model name as registered in LiteLLM config (model_name: whisper)
SPEACHES_MODEL=whisper
# Max seconds to wait for a transcription response
SPEACHES_TIMEOUT_SECONDS=300

# ── MCP service ───────────────────────────────────────────────────────────────
# Shared secret between the REST API and the MCP microservice.
# MCP_SERVICE_KEY   — REST API uses this to verify inbound calls from MCP.
# MCP_SERVICE_API_KEY — MCP container uses this to authenticate to the REST API.
# Both values must be identical; generate with: openssl rand -hex 32
MCP_SERVICE_KEY=
MCP_SERVICE_API_KEY=

# ── Shell WS RPC bridge ───────────────────────────────────────────────────────
# Shell service forwards WebSocket sessions between the browser and GoClaw.
# docker-compose overrides URL to the shell container.
SHELL_SERVICE_URL=http://shell-shell-1:18080
# Shared secret — must match SHELL_SERVICE_KEY in shell/.env
SHELL_SERVICE_KEY=shell-service-key

# ── Frontend ──────────────────────────────────────────────────────────────────
# Used for CORS allowlist and OAuth redirect validation.
FRONTEND_URL=http://localhost:3000

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── GoClaw AI agent gateway ───────────────────────────────────────────────────
# GoClaw is the agent runtime that manages workspaces, LLM providers, and skills.

# Admin API base URL.
# docker-compose overrides to the goclaw container; this value is for local dev.
GOCLAW_GATEWAY_URL=http://localhost:18790
# Bearer token for the GoClaw admin API (set in goclaw/.env as GATEWAY_TOKEN)
GOCLAW_GATEWAY_TOKEN=

# Default LLM model assigned to new workspace agents.
# Must match a model_name exposed by the active LiteLLM config.
GOCLAW_DEFAULT_MODEL=qwen3

# LiteLLM proxy — two URLs are needed:
# GOCLAW_LITELLM_URL      — internal URL the REST API uses when calling LiteLLM
#                           (docker-compose overrides to http://litellm:4000/v1)
# GOCLAW_LITELLM_API_BASE — public URL registered as the provider's api_base in GoClaw
#                           (must be reachable from the GoClaw container; use host IP or domain)
GOCLAW_LITELLM_URL=http://localhost:4000/v1
GOCLAW_LITELLM_API_BASE=http://<host-ip>:4000/v1
# LiteLLM master key — must match LITELLM_MASTER_KEY in llms/.env
GOCLAW_LITELLM_API_KEY=sk-local-dev

# MCP server URL as seen FROM the GoClaw container (use host IP if on a different machine)
GOCLAW_MCP_URL=http://<host-ip>:8002/mcp
# Prefix applied to MCP tools registered in GoClaw (e.g. "ws" → ws__rag_search)
GOCLAW_MCP_TOOL_PREFIX=ws

# Embedding model registered with GoClaw for vector memory.
# Must match a model_name in the active LiteLLM config.
GOCLAW_EMBEDDING_MODEL=text-embedding-qwen3

# TTS settings applied to every new workspace agent:
# Provider: openai (routes through LiteLLM → Speaches/Kokoro) | edge | off
GOCLAW_TTS_PROVIDER=off
# Auto mode: off | always | inbound (voice reply when user sent voice) | tagged
GOCLAW_TTS_AUTO=inbound
# Voice for openai/Speaches provider (Kokoro voices: af_heart, af_sky, am_adam, ...)
GOCLAW_TTS_VOICE=af_heart
# Edge TTS fallback voice — see: edge-tts --list-voices
GOCLAW_TTS_EDGE_VOICE=en-US-JennyNeural

# Comma-separated skill catalog names granted to every new workspace agent
GOCLAW_DEFAULT_SKILLS=workspace-assistant
# Path to the skill manifests directory inside the container (mounted via docker-compose)
GOCLAW_SKILLS_DIR=/skills
# Agent type: open (per-user context files) | predefined (shared context)
GOCLAW_AGENT_TYPE=open
# Optional agent personality description — used to generate SOUL.md/IDENTITY.md in GoClaw
GOCLAW_AGENT_DESCRIPTION=

# How often (seconds) background sync reconciles GoClaw sessions → REST conversations
# Set to 0 to disable.
GOCLAW_SYNC_INTERVAL_SECONDS=300
